generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model community {
  id                Int                 @id @default(autoincrement())
  title             String              @db.VarChar(255)
  content           String              @db.VarChar(255)
  like_count        Int?                @default(0)
  user_id           Int
  created_at        DateTime?           @default(now()) @db.Timestamp(0)
  updated_at        DateTime?           @default(now()) @db.Timestamp(0)
  deleted_at        DateTime?           @db.Timestamp(0)
  media_id          Int?
  media             media?              @relation(fields: [media_id], references: [id], onDelete: Cascade, map: "community_media_FK")
  user              user                @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "community_user_FK")
  community_comment community_comment[]
  reactions         reactions[]

  @@index([user_id], map: "community_user_FK")
  @@index([media_id], map: "community_media_FK")
}

model community_comment {
  id           Int       @id @default(autoincrement())
  content      String    @db.VarChar(255)
  community_id Int
  user_id      Int
  created_at   DateTime? @default(now()) @db.Timestamp(0)
  deleted_at   DateTime? @db.Timestamp(0)
  comment_id   Int?
  community    community @relation(fields: [community_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "community_comment_community_FK")
  user         user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "community_comment_user_FK")

  @@index([community_id], map: "community_comment_community_FK")
  @@index([user_id], map: "community_comment_user_FK")
}

model location {
  id         Int    @id @default(autoincrement())
  upper_code String @db.VarChar(255)
  lower_code String @db.VarChar(255)
  nx         Int
  ny         Int
}

model user {
  id                Int                 @id @default(autoincrement())
  email             String              @unique(map: "user_unique") @db.VarChar(100)
  password          String              @db.VarChar(255)
  name              String              @unique(map: "user_unique_1") @db.VarChar(8)
  created_at        DateTime            @default(now()) @db.Timestamp(0)
  deleted_at        DateTime?           @db.Timestamp(0)
  media_id          Int?
  closet            closet[]
  community         community[]
  community_comment community_comment[]
  reactions         reactions[]
  media             media?              @relation(fields: [media_id], references: [id], onDelete: Cascade, map: "user_media_FK")
  user_info         user_info[]

  @@index([media_id], map: "user_media_FK")
}

model user_info {
  id             Int       @id @default(autoincrement())
  user_id        Int
  personal_color String?   @db.VarChar(50)
  style          String?   @db.VarChar(10)
  height         Int?
  weight         Int?
  gender         String?   @db.VarChar(10)
  birth_at       DateTime? @db.Date
  user           user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_info_user_FK")

  @@index([user_id], map: "user_info_user_FK")
}

model media {
  id         Int         @id @default(autoincrement())
  key        String      @db.VarChar(255)
  type       String      @db.VarChar(255)
  created_at DateTime    @default(now()) @db.Timestamp(0)
  deleted_at DateTime?   @db.Timestamp(0)
  closet     closet[]
  community  community[]
  user       user[]
}

model closet {
  id             Int       @id @default(autoincrement())
  user_id        Int
  media_id       Int
  created_at     DateTime  @default(now()) @db.Timestamp(0)
  deleted_at     DateTime? @db.Timestamp(0)
  color          String    @db.VarChar(50)
  upper_category String    @db.VarChar(20)
  lower_category String    @db.VarChar(20)
  accuracy       Float     @db.Float
  media          media     @relation(fields: [media_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "closet_media_FK")
  user           user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "closet_user_FK")

  @@index([media_id], map: "closet_media_FK")
  @@index([user_id], map: "closet_user_FK")
}

model reactions {
  id           Int       @id @default(autoincrement())
  emoji        String    @db.VarChar(10)
  community_id Int
  user_id      Int
  created_at   DateTime  @default(now()) @db.Timestamp(0)
  deleted_at   DateTime? @db.Timestamp(0)
  community    community @relation(fields: [community_id], references: [id], onDelete: Cascade, map: "reactions_community_FK")
  user         user      @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "reactions_user_FK")

  @@index([community_id], map: "reactions_community_FK")
  @@index([user_id], map: "reactions_user_FK")
}
